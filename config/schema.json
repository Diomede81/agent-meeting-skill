{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Meeting Skill Configuration",
  "type": "object",
  "properties": {
    "bot": {
      "type": "object",
      "title": "Bot Settings",
      "properties": {
        "name": {
          "type": "string",
          "title": "Bot Name",
          "description": "Name displayed in meetings",
          "default": "Assistant"
        },

        "introMessage": {
          "type": "string",
          "title": "Introduction Message",
          "description": "Message sent to meeting chat on join. Use {name} for bot name.",
          "default": "👋 Hi, I'm {name} - I'm here to take notes for this meeting."
        }
      },
      "required": ["name"]
    },
    "calendar": {
      "type": "object",
      "title": "Calendar Settings",
      "properties": {
        "source": {
          "type": "string",
          "title": "Calendar Source",
          "enum": ["microsoft", "google", "ical", "api"],
          "default": "api",
          "description": "Calendar provider type"
        },
        "endpoint": {
          "type": "string",
          "title": "Calendar API Endpoint",
          "description": "URL for calendar API (e.g., http://localhost:3007/api/calendar)",
          "format": "uri"
        },
        "agent": {
          "type": "string",
          "title": "Calendar Agent/Account",
          "description": "Agent name for calendar API authentication"
        },
        "pollIntervalMinutes": {
          "type": "integer",
          "title": "Poll Interval (minutes)",
          "description": "How often to check for upcoming meetings",
          "default": 5,
          "minimum": 1,
          "maximum": 60
        },
        "joinWindowMinutes": {
          "type": "integer",
          "title": "Join Window (minutes)",
          "description": "Join meetings starting within this many minutes",
          "default": 5,
          "minimum": 1,
          "maximum": 30
        }
      },
      "required": ["source"]
    },
    "transcription": {
      "type": "object",
      "title": "Transcription Settings",
      "properties": {
        "provider": {
          "type": "string",
          "title": "Transcription Provider",
          "enum": ["recall", "deepgram", "whisper"],
          "default": "recall"
        },
        "region": {
          "type": "string",
          "title": "Provider Region",
          "description": "API region for transcription provider",
          "default": "eu-central-1"
        },
        "speakerDiarization": {
          "type": "boolean",
          "title": "Speaker Identification",
          "description": "Identify who said what",
          "default": true
        },
        "language": {
          "type": "string",
          "title": "Language",
          "description": "Primary language for transcription",
          "default": "en"
        }
      }
    },
    "meetings": {
      "type": "object",
      "title": "Meeting Behavior",
      "properties": {
        "autoJoin": {
          "type": "boolean",
          "title": "Auto-Join Meetings",
          "description": "Automatically join meetings from calendar",
          "default": true
        },
        "autoLeave": {
          "type": "boolean",
          "title": "Auto-Leave on End",
          "description": "Automatically leave when meeting ends",
          "default": true
        },
        "leaveDelaySeconds": {
          "type": "integer",
          "title": "Leave Delay (seconds)",
          "description": "Wait this long after meeting appears to end",
          "default": 30,
          "minimum": 0,
          "maximum": 300
        },
        "sendIntroMessage": {
          "type": "boolean",
          "title": "Send Introduction",
          "description": "Send intro message to meeting chat",
          "default": true
        }
      }
    },
    "storage": {
      "type": "object",
      "title": "Storage Settings",
      "properties": {
        "transcriptFormat": {
          "type": "string",
          "title": "Transcript Format",
          "enum": ["markdown", "json", "txt"],
          "default": "markdown"
        },
        "fileNamePattern": {
          "type": "string",
          "title": "File Name Pattern",
          "description": "Pattern for transcript filenames. Use {date}, {title}, {time}",
          "default": "{date}_{title}"
        }
      }
    },
    "webhook": {
      "type": "object",
      "title": "Agent Webhook",
      "description": "Notify agent when meeting ends for summarization and action extraction",
      "properties": {
        "onMeetingEnd": {
          "type": "string",
          "title": "Webhook URL",
          "description": "URL to POST when meeting completes (e.g., http://localhost:18789/webhook/meeting-complete)",
          "format": "uri"
        },
        "includeTranscript": {
          "type": "boolean",
          "title": "Include Full Transcript",
          "description": "Send full transcript in webhook payload (vs just file path)",
          "default": true
        },
        "retryCount": {
          "type": "integer",
          "title": "Retry Count",
          "description": "Number of retry attempts if webhook fails",
          "default": 3,
          "minimum": 0,
          "maximum": 10
        }
      }
    },
    "cron": {
      "type": "object",
      "title": "Cron Settings",
      "description": "Configure polling intervals (managed by OpenClaw cron)",
      "properties": {
        "calendarPollEnabled": {
          "type": "boolean",
          "title": "Enable Calendar Polling",
          "description": "Automatically check calendar for meetings to join",
          "default": true
        },
        "calendarPollIntervalMs": {
          "type": "integer",
          "title": "Calendar Poll Interval (ms)",
          "description": "How often to check calendar (default: 5 minutes)",
          "default": 300000,
          "minimum": 60000,
          "maximum": 3600000
        },
        "meetingCheckEnabled": {
          "type": "boolean",
          "title": "Enable Meeting Status Check",
          "description": "Monitor active meetings for completion",
          "default": true
        },
        "meetingCheckIntervalMs": {
          "type": "integer",
          "title": "Meeting Check Interval (ms)",
          "description": "How often to check active meeting status (default: 60 seconds)",
          "default": 60000,
          "minimum": 30000,
          "maximum": 300000
        }
      }
    },
    "platforms": {
      "type": "object",
      "title": "Enabled Platforms",
      "properties": {
        "teams": {
          "type": "boolean",
          "title": "Microsoft Teams",
          "default": true
        },
        "zoom": {
          "type": "boolean",
          "title": "Zoom",
          "default": true
        },
        "meet": {
          "type": "boolean",
          "title": "Google Meet",
          "default": true
        }
      }
    },
    "delivery": {
      "type": "object",
      "title": "Transcript Delivery",
      "description": "How and where to deliver meeting transcripts after completion",
      "properties": {
        "mode": {
          "type": "string",
          "title": "Delivery Mode",
          "description": "What to send after meeting ends",
          "enum": ["summary", "both", "none"],
          "default": "summary",
          "enumDescriptions": {
            "summary": "AI-generated summary with action items, decisions, and speaker highlights (recommended)",
            "both": "Summary plus full transcript",
            "none": "Save locally only, no email delivery"
          }
        },
        "channels": {
          "type": "array",
          "title": "Delivery Channels",
          "description": "Where to send the transcript/summary",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "title": "Channel Type",
                "enum": ["email", "webhook"],
                "description": "Delivery channel (email or webhook)"
              },
              "enabled": {
                "type": "boolean",
                "title": "Enabled",
                "default": true
              },
              "target": {
                "type": "string",
                "title": "Target",
                "description": "Email address or webhook URL"
              },
              "agent": {
                "type": "string",
                "title": "Agent/Account",
                "description": "Agent account to send from (for email/teams)"
              }
            },
            "required": ["type", "target"]
          }
        },
        "summaryOptions": {
          "type": "object",
          "title": "Summary Options",
          "description": "Configure what to include in the AI summary",
          "properties": {
            "includeActionItems": {
              "type": "boolean",
              "title": "Include Action Items",
              "description": "Extract and list action items with assignees",
              "default": true
            },
            "includeSpeakerHighlights": {
              "type": "boolean",
              "title": "Include Speaker Highlights",
              "description": "Main points per speaker",
              "default": true
            },
            "includeDecisions": {
              "type": "boolean",
              "title": "Include Decisions",
              "description": "Key decisions made during the meeting",
              "default": true
            },
            "includeFollowUps": {
              "type": "boolean",
              "title": "Include Follow-ups",
              "description": "Items that need follow-up",
              "default": true
            },
            "maxLength": {
              "type": "integer",
              "title": "Max Summary Length",
              "description": "Maximum characters for summary (0 = no limit)",
              "default": 0,
              "minimum": 0
            }
          }
        }
      }
    }
  },
    "cron": {
      "type": "object",
      "title": "Cron Job Settings",
      "description": "Configure automated polling jobs",
      "properties": {
        "calendarPollEnabled": {
          "type": "boolean",
          "title": "Enable Calendar Polling",
          "description": "Automatically check calendar for upcoming meetings",
          "default": true
        },
        "calendarPollIntervalMs": {
          "type": "integer",
          "title": "Calendar Poll Interval (ms)",
          "description": "How often to check calendar (default: 60000 = 1 minute)",
          "default": 60000,
          "minimum": 30000,
          "maximum": 300000
        },
        "meetingCheckEnabled": {
          "type": "boolean",
          "title": "Enable Meeting Status Check",
          "description": "Monitor active meetings for completion",
          "default": true
        },
        "meetingCheckIntervalMs": {
          "type": "integer",
          "title": "Meeting Check Interval (ms)",
          "description": "How often to check meeting status (default: 60000 = 1 minute)",
          "default": 60000,
          "minimum": 30000,
          "maximum": 300000
        },
        "gatewayUrl": {
          "type": "string",
          "title": "OpenClaw Gateway URL",
          "description": "URL for cron job installation (default: http://localhost:18789)",
          "default": "http://localhost:18789",
          "format": "uri"
        }
      }
    }
  },
  "required": ["bot", "calendar"]
}
