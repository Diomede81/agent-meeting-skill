{
  "bot": {
    "name": "Max",
    "introMessage": "👋 Hi, I'm {name} - I'm here to take notes for this meeting."
  },
  "calendar": {
    "source": "api",
    "endpoint": "http://localhost:3007/api/calendar",
    "agent": "luca",
    "pollIntervalMinutes": 5,
    "joinWindowMinutes": 5
  },
  "transcription": {
    "provider": "recall",
    "region": "eu-central-1",
    "speakerDiarization": true
  },
  "meetings": {
    "autoJoin": true,
    "autoLeave": true,
    "leaveDelaySeconds": 30,
    "sendIntroMessage": true
  },
  "storage": {
    "transcriptFormat": "markdown",
    "fileNamePattern": "{date}_{title}"
  },
  "platforms": {
    "teams": true,
    "zoom": true,
    "meet": true
  },
  "delivery": {
    "mode": "summary",
    "channels": [
      {"type": "email", "enabled": true, "target": "", "agent": "max"}
    ],
    "summaryOptions": {
      "includeActionItems": true,
      "includeSpeakerHighlights": true,
      "includeDecisions": true,
      "includeFollowUps": true,
      "maxLength": 0
    }
  },
  "webhook": {
    "onMeetingEnd": null,
    "includeTranscript": true,
    "retryCount": 3
  },
  "cron": {
    "calendarPollEnabled": true,
    "calendarPollIntervalMs": 60000,
    "meetingCheckEnabled": true,
    "meetingCheckIntervalMs": 60000,
    "gatewayUrl": "http://localhost:18789"
  }
}
