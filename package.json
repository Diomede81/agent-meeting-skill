{
  "name": "agent-meeting-skill",
  "version": "1.0.0",
  "description": "OpenClaw skill for automated meeting attendance and transcription",
  "main": "scripts/server.js",
  "scripts": {
    "start": "node scripts/server.js",
    "dev": "node --watch scripts/server.js",
    "poll": "node scripts/calendar-poll.js",
    "poll:dry": "node scripts/calendar-poll.js --dry-run",
    "monitor": "node scripts/monitor.js",
    "monitor:continuous": "node scripts/monitor.js --continuous",
    "complete": "node scripts/meeting-complete.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "keywords": [
    "openclaw",
    "skill",
    "meeting",
    "transcription",
    "recall.ai"
  ],
  "author": "Luca Licata",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "jest": "^30.3.0"
  }
}
